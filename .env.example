# ============================================================================
# StackSage — Environment Variables
# Copy this file to .env and fill in real values.  All API keys below are
# from free tiers that do NOT require a credit card.
# ============================================================================

# ── App ──────────────────────────────────────────────────────────────────
DEBUG=false

# ── LLM Provider ─────────────────────────────────────────────────────────
# Options: "groq" (default, free) or "gemini" (fallback, free)
LLM_PROVIDER=groq

# Groq — https://console.groq.com (free, no credit card)
# Model: llama-3.3-70b-versatile or mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini — https://aistudio.google.com (free, no credit card)
# Used for: fallback LLM (gemini-2.0-flash) AND embeddings (text-embedding-004)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Reranking ────────────────────────────────────────────────────────────
# Cohere — https://dashboard.cohere.com (free tier, no credit card)
COHERE_API_KEY=your_cohere_api_key_here

# ── Vector Database ──────────────────────────────────────────────────────
# Qdrant Cloud — https://cloud.qdrant.io (free tier, 1GB storage)
# During dev: use Qdrant Cloud.  In prod: can use local Docker container.
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Auth (Clerk) ─────────────────────────────────────────────────────────
# Clerk — https://dashboard.clerk.com (free up to 10k MAU)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Database ─────────────────────────────────────────────────────────────
# SQLite (default, zero config).  To upgrade to PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/stacksage
DATABASE_URL=sqlite+aiosqlite:///./stacksage.db

# ── Redis (Celery broker) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── RAG Scheduling ──────────────────────────────────────────────────────
# Set to "true" only on deployment (Railway).  Locally, trigger refresh
# manually via POST /api/admin/refresh-rag or the dashboard button.
ENABLE_SCHEDULED_RAG_REFRESH=false

# ── CORS ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
